{
  "name": "dashboard-lab",
  "version": "0.1.4",
  "private": true,
  "license": "MIT",
  "description": "Local-first AI workspace dashboard boilerplate with Electron desktop packaging.",
  "author": "dashboard-LAB contributors",
  "main": "electron/main.mjs",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "setup:mac": "bash scripts/bootstrap-macos.sh",
    "launch": "node scripts/launch-local.mjs",
    "dev": "node server/run-local.mjs dev",
    "build": "node scripts/next-build.mjs",
    "start": "node server/run-local.mjs start",
    "assets:icon": "node scripts/generate-app-icon.mjs",
    "desktop:dev": "node electron/dev-runner.mjs",
    "desktop:build": "node scripts/desktop-build.mjs dir",
    "desktop:dist": "node scripts/desktop-build.mjs dist",
    "desktop:dist:mac": "node scripts/desktop-build.mjs dist:mac",
    "desktop:dist:win": "node scripts/desktop-build.mjs dist:win",
    "desktop:dist:linux": "node scripts/desktop-build.mjs dist:linux",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "next": "15.3.8",
    "node-html-parser": "^7.1.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-file-icon": "^1.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "node-pty": "1.2.0-beta.12",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "15.3.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "lab.dashboard.desktop",
    "productName": "dashboard-LAB",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "icon": "build-resources/icon.png",
    "files": [
      "build-resources/**/*",
      "electron/**/*",
      "server/**/*",
      "scripts/**/*",
      "src/**/*",
      "public/**/*",
      ".next/**/*",
      "cs-contexts/**/*",
      "data/**/*",
      "models/**/*",
      "package.json",
      "next.config.ts",
      "postcss.config.mjs",
      "tsconfig.json"
    ],
    "mac": {
      "icon": "build-resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "icon": "build-resources/icon.png",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Utility"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "sharp",
      "unrs-resolver"
    ]
  }
}
